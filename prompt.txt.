void drawRectangle(int row, int col, int width, int height)
{
    int i;

    // Top and Bottom
    for(i = col; i < col + width; i++)
    {
        canvas[row][i] = '*';
        canvas[row + height - 1][i] = '*';
    }

    // Left and Right
    for(i = row; i < row + height; i++)
    {
        canvas[i][col] = '*';
        canvas[i][col + width - 1] = '*';
    }
}
