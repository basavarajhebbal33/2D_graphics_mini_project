void drawCircle(int xc, int yc, int r)
{
    // Check boundary
    if(xc-r < 0 || xc+r >= ROWS ||
       yc-r < 0 || yc+r >= COLS)
    {
        printf("Circle out of bounds\n");
        return;
    }

    // Draw circle
    for(int x = 0; x < ROWS; x++)
    {
        for(int y = 0; y < COLS; y++)
        {
            int d = (x-xc)*(x-xc) + (y-yc)*(y-yc);

            if(abs(d - r*r) <= 1)
                canvas[x][y] = '*';
        }
    }
}
